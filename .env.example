# Firebase web config. Copy this file to `.env.local` and fill in real values
# for local development (`.env.local` is git-ignored).
#
# In CI, these are injected from GitHub Actions repository secrets of the same
# name (see .github/workflows/deploy.yml).

# --- Def the Base (primary project) ---
VITE_FB_DEF_THE_BASE_API_KEY=
VITE_FB_DEF_THE_BASE_AUTH_DOMAIN=
VITE_FB_DEF_THE_BASE_PROJECT_ID=
VITE_FB_DEF_THE_BASE_STORAGE_BUCKET=
VITE_FB_DEF_THE_BASE_MESSAGING_SENDER_ID=
VITE_FB_DEF_THE_BASE_APP_ID=

# --- Jumping Jello (secondary project) ---
VITE_FB_JUMPING_JELLO_API_KEY=
VITE_FB_JUMPING_JELLO_AUTH_DOMAIN=
VITE_FB_JUMPING_JELLO_PROJECT_ID=
VITE_FB_JUMPING_JELLO_STORAGE_BUCKET=
VITE_FB_JUMPING_JELLO_MESSAGING_SENDER_ID=
VITE_FB_JUMPING_JELLO_APP_ID=
