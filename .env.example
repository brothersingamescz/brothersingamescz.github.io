# Firebase web config. Copy this file to `.env.local` and fill in real values
# for local development (`.env.local` is git-ignored).
#
# In CI, these are injected from GitHub Actions repository secrets of the same
# name (see .github/workflows/deploy.yml).
#
# NOTE: these are NOT secrets. The Firebase web config is public by design and
# ships in the browser bundle. Data is protected by Firebase Auth + Firestore
# Security Rules, not by keeping these hidden. They live in env vars only to keep
# project identifiers out of source.
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
